{
  "name": "node-api",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js API service for Learn-Project",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "type-check": "tsc --noEmit",
    "db:init": "tsx src/scripts/init-db.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/mongodb": "^8.0.0",
    "@fastify/postgres": "^5.2.2",
    "fastify": "^5.7.4",
    "fastify-plugin": "^4.5.1",
    "mongodb": "^6.3.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
